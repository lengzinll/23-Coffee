<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <system.webServer>
        <handlers>
            <!-- iisnode will handle all Node.js requests via server.js -->
            <add name="iisnode" path="server.js" verb="*" modules="iisnode" />
        </handlers>
        <rewrite>
            <rules>
                <!-- Redirect all requests to server.js except for specific static files if needed -->
                <rule name="NextJs" stopProcessing="true">
                    <match url="/*" />
                    <action type="Rewrite" url="server.js" />
                </rule>
            </rules>
        </rewrite>
        
        <iisnode 
            node_env="production" 
            nodeProcessCommandLine="&quot;%programfiles%\nodejs\node.exe&quot;"
            watchedFiles="web.config;*.js"
            loggingEnabled="true"
            devErrorsEnabled="true"
        />

        <httpErrors errorMode="Detailed" />
    </system.webServer>

    <!-- 
      Note: iisnode doesn't natively read <appSettings>. 
      Please ensure you have a .env file in your folder with:
      DATABASE_URL="file:sqlite.db"
    -->
</configuration>
